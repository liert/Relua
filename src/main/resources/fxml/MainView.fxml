<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ComboBox?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.relua.gui.controllers.MainController">
    <!-- 菜单栏 -->
    <top>
        <MenuBar>
            <menus>
                <!-- 文件菜单 -->
                <Menu fx:id="menuFile">
                    <items>
                        <MenuItem fx:id="menuItemOpen" onAction="#handleOpenFile" />
                        <MenuItem fx:id="menuItemOpenFolder" onAction="#handleOpenFolder" />
                        <MenuItem fx:id="menuItemSave" onAction="#handleSaveFile" />
                        <MenuItem fx:id="menuItemSaveAs" onAction="#handleSaveAsFile" />
                        <SeparatorMenuItem />
                        <MenuItem fx:id="menuItemExit" onAction="#handleExit" />
                    </items>
                </Menu>
                
                <!-- 编辑菜单 -->
                <Menu fx:id="menuEdit">
                    <items>
                        <MenuItem fx:id="menuItemUndo" onAction="#handleUndo" />
                        <MenuItem fx:id="menuItemRedo" onAction="#handleRedo" />
                        <SeparatorMenuItem />
                        <MenuItem fx:id="menuItemCut" onAction="#handleCut" />
                        <MenuItem fx:id="menuItemCopy" onAction="#handleCopy" />
                        <MenuItem fx:id="menuItemPaste" onAction="#handlePaste" />
                    </items>
                </Menu>
                
                <!-- 视图菜单 -->
                <Menu fx:id="menuView">
                    <items>
                        <!-- 子视图子菜单 -->
                        <Menu text="子视图">
                            <items>
                                <MenuItem fx:id="menuItemBytecodeView" onAction="#handleBytecodeView" text="字节码视图" />
                                <MenuItem fx:id="menuItemAstView" onAction="#handleAstView" text="AST视图" />
                                <MenuItem fx:id="menuItemCfgView" onAction="#handleCfgView" text="CFG视图" />
                            </items>
                        </Menu>
                        <!-- 缩放相关菜单项 -->
                        <MenuItem fx:id="menuItemZoomIn" onAction="#handleZoomIn" />
                        <MenuItem fx:id="menuItemZoomOut" onAction="#handleZoomOut" />
                        <MenuItem fx:id="menuItemResetZoom" onAction="#handleResetZoom" />
                    </items>
                </Menu>
                
                <!-- 帮助菜单 -->
                <Menu fx:id="menuHelp">
                    <items>
                        <MenuItem fx:id="menuItemAbout" onAction="#handleAbout" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    
    <!-- 工具栏 -->
    <center>
        <VBox>
            <ToolBar>
                <Button fx:id="btnOpen" onAction="#handleOpenFile" />
                <Button fx:id="btnSave" onAction="#handleSaveFile" />
                <Separator orientation="VERTICAL" />
                <Button fx:id="btnUndo" onAction="#handleUndo" />
                <Button fx:id="btnRedo" onAction="#handleRedo" />
                <Separator orientation="VERTICAL" />
                <Button fx:id="btnZoomIn" onAction="#handleZoomIn" />
                <Button fx:id="btnZoomOut" onAction="#handleZoomOut" />
                <Button fx:id="btnResetZoom" onAction="#handleResetZoom" />
                <Separator orientation="VERTICAL" />
                
            </ToolBar>
            
            <!-- 主内容区域和日志窗口的垂直分割面板 -->
            <SplitPane fx:id="verticalSplitPane" orientation="VERTICAL" VBox.vgrow="ALWAYS" dividerPositions="0.8">
                <!-- 主内容区域 - 水平分割面板 -->
                <SplitPane fx:id="mainSplitPane" orientation="HORIZONTAL" VBox.vgrow="ALWAYS" dividerPositions="0.2, 0.6">
                    <!-- 左侧：文件树导航区域 -->
                    <VBox fx:id="fileTreeContainer" prefWidth="250" minWidth="150" maxWidth="500">
                        <ScrollPane fx:id="fileTreeScrollPane" VBox.vgrow="ALWAYS" prefHeight="0">
                            <!-- 文件树控件将通过代码添加 -->
                        </ScrollPane>
                    </VBox>
                    
                    <!-- 中间：文本编辑区域 -->
                    <VBox fx:id="textEditorContainer">
                        <Label fx:id="luaCodeLabel" style="-fx-font-weight: bold;" />
                        <ScrollPane fx:id="textEditorScrollPane" VBox.vgrow="ALWAYS" prefHeight="0">
                            <!-- 文本编辑器将通过代码添加 -->
                        </ScrollPane>
                    </VBox>
                    
                    <!-- 右侧：图形可视化区域 -->
                    <VBox fx:id="graphContainer">
                        <Label fx:id="astGraphLabel" style="-fx-font-weight: bold;" />
                        <ScrollPane fx:id="graphScrollPane" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" fitToWidth="true" fitToHeight="true">
                            <!-- 图形可视化组件将通过代码添加 -->
                        </ScrollPane>
                    </VBox>
                </SplitPane>
                
                <!-- 日志输出窗口区域 -->
                <VBox fx:id="logContainer">
                    <HBox style="-fx-padding: 5px; -fx-background-color: #f0f0f0; -fx-border-color: #d0d0d0; -fx-border-width: 1px 0 0 0;">
                        <Label fx:id="logLabel" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="logLevelComboBox" style="-fx-margin-left: 10px; -fx-min-width: 100px;" />
                        <Button fx:id="btnClearLog" style="-fx-margin-left: auto;" />
                    </HBox>
                    <ScrollPane fx:id="logScrollPane" VBox.vgrow="ALWAYS" prefHeight="0">
                        <!-- 日志文本区域将通过代码添加 -->
                    </ScrollPane>
                </VBox>
            </SplitPane>
            
            <!-- 状态栏 -->
            <HBox style="-fx-background-color: #f0f0f0; -fx-padding: 5px;" BorderPane.alignment="CENTER">
                <Label fx:id="statusLabel" />
                <Label text=" | " />
                <Label fx:id="fileLabel" />
            </HBox>
        </VBox>
    </center>
</BorderPane>